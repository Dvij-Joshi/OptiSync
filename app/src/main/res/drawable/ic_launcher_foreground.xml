<?xml version="1.0" encoding="utf-8"?>
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:aapt="http://schemas.android.com/aapt"
    android:width="108dp"
    android:height="108dp"
    android:viewportWidth="108"
    android:viewportHeight="108">
    
    <!-- Outer tracking scanner brackets -->
    <path
        android:pathData="M 16,36 Q 6,54 16,72"
        android:strokeColor="#1E88E5"
        android:strokeWidth="2"
        android:strokeLineCap="round"
        android:fillColor="#00000000" />
    <path
        android:pathData="M 92,36 Q 102,54 92,72"
        android:strokeColor="#1E88E5"
        android:strokeWidth="2"
        android:strokeLineCap="round"
        android:fillColor="#00000000" />

    <!-- Stylized Eye Lens Shape -->
    <path
        android:pathData="M 24,54 Q 54,23 84,54 Q 54,85 24,54 Z"
        android:strokeColor="#00E5FF"
        android:strokeWidth="3.5"
        android:strokeLineJoin="round"
        android:fillColor="#15004080" />

    <!-- Iris (Blue Gradient) -->
    <path
        android:pathData="M 54,54 m -18,0 a 18,18 0 1,0 36,0 a 18,18 0 1,0 -36,0">
        <aapt:attr name="android:fillColor">
            <gradient
                android:centerX="54"
                android:centerY="54"
                android:gradientRadius="18"
                android:type="radial">
                <item android:color="#00E5FF" android:offset="0.0" />
                <item android:color="#0066FF" android:offset="0.7" />
                <item android:color="#0B2341" android:offset="1.0" />
            </gradient>
        </aapt:attr>
    </path>

    <!-- Pupil -->
    <path
        android:pathData="M 54,54 m -8.5,0 a 8.5,8.5 0 1,0 17,0 a 8.5,8.5 0 1,0 -17,0"
        android:fillColor="#020B1A" />

    <!-- Lens Reflection Highlights -->
    <path
        android:pathData="M 50,50 m -2.5,0 a 2.5,2.5 0 1,0 5,0 a 2.5,2.5 0 1,0 -5,0"
        android:fillColor="#FFFFFF" />

    <path
        android:pathData="M 59,57 m -1.2,0 a 1.2,1.2 0 1,0 2.4,0 a 1.2,1.2 0 1,0 -2.4,0"
        android:fillColor="#90CAFF" />
</vector>
